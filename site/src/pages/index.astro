    <!-- Progressive enhancement: point download buttons at the newest release
         assets. Static fallbacks (the releases page) work without JS. -->
    <script is:inline>
      (function () {
        var pick = {
          "dl-win-exe": function (n) { return /^Eqho-Setup-.*\.exe$/.test(n); },
          "dl-win-zip": function (n) { return /portable.*\.zip$/i.test(n); },
          "dl-linux-appimage": function (n) { return /\.AppImage$/.test(n); },
          "dl-linux-tar": function (n) { return /\.tar\.gz$/.test(n); },
          "dl-mac-dmg": function (n) { return /\.dmg$/.test(n); },
          "dl-hero": function (n) { return /^Eqho-Setup-.*\.exe$/.test(n); }
        };
        fetch("https://api.github.com/repos/danielmevit/eqho/releases/latest")
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (rel) {
            if (!rel || !rel.assets) return;
            Object.keys(pick).forEach(function (id) {
              var el = document.getElementById(id);
              if (!el) return;
              var asset = rel.assets.find(function (a) { return pick[id](a.name); });
              if (asset) el.href = asset.browser_download_url;
            });
            if (rel.tag_name) {
              document.querySelectorAll(".rel-version").forEach(function (el) {
                el.textContent = "Eqho " + rel.tag_name.replace(/^v/, "");
              });
            }
          })
          .catch(function () { /* fallbacks already point at the releases page */ });
      })();
    </script>
  </body>
